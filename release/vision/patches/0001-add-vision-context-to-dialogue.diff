+        # --- Vision 컨텍스트 (Phase 1: 에뮬레이터, Phase 2+: DeepStream) ---
+        self.declare_parameter("vision_enabled", False)
+        self.declare_parameter("vision_topic", "/vision/state")
+        # 이 시간(초) 보다 오래된 vision 데이터는 무시
+        self.declare_parameter("vision_stale_s", 3.0)

         self.endpoint = self.get_parameter("llm_endpoint").value
         self.model_name = self.get_parameter("model_name").value
@@ -110,6 +116,16 @@ class LlmDialogueNode(Node):
                 )
                 self._rag = None

+        # --- Vision state (lazy subscribe) ---
+        self._vision_state: dict = {}
+        self._vision_ts: float = 0.0
+        if self.get_parameter("vision_enabled").value:
+            topic = self.get_parameter("vision_topic").value
+            self.create_subscription(String, topic, self._on_vision_state, 10)
+            self.get_logger().info(
+                f"Vision context enabled. topic={topic}"
+            )
+
         self._history: "deque[dict]" = deque(maxlen=self.history_turns * 2)
         self._turn_id = 0
         self._lock = threading.Lock()
@@ -123,9 +139,37 @@ class LlmDialogueNode(Node):
             f"history_turns={self.history_turns}, "
             f"hooks(sv={self.get_parameter('sv_enabled').value}, "
             f"rag={self.get_parameter('rag_enabled').value}, "
+            f"vision={self.get_parameter('vision_enabled').value}, "
             f"guard={self.get_parameter('guardrails_enabled').value})"
         )

+    # ------------------------------------------------------------------
+    # Vision 콜백
+    # ------------------------------------------------------------------
+    def _on_vision_state(self, msg: String) -> None:
+        try:
+            state = json.loads(msg.data)
+            if not isinstance(state, dict):
+                return
+        except Exception as exc:
+            self.get_logger().warn(f"Bad vision payload: {exc}")
+            return
+        with self._lock:
+            self._vision_state = state
+            self._vision_ts = time.time()
+
+    def _vision_context_block(self) -> str | None:
+        """현재 vision 상태를 LLM 시스템 메시지로 변환. stale/empty 이면 None."""
+        with self._lock:
+            state = dict(self._vision_state)
+            ts = self._vision_ts
+        if not state:
+            return None
+        stale_s = float(self.get_parameter("vision_stale_s").value)
+        if (time.time() - ts) > stale_s:
+            return None
+        return _format_vision_for_prompt(state)
+
     def _on_transcript(self, msg: String):
         try:
             payload = json.loads(msg.data)
@@ -174,6 +218,12 @@ class LlmDialogueNode(Node):
                 except Exception as exc:
                     self.get_logger().warn(f"RAG retrieve failed: {exc}")

+            # --- Vision 컨텍스트 주입 ---
+            if self.get_parameter("vision_enabled").value:
+                vblock = self._vision_context_block()
+                if vblock:
