+
             messages.extend(list(self._history))
             messages.append({"role": "user", "content": user_text})

@@ -226,6 +276,41 @@ class LlmDialogueNode(Node):
         )


+# ----------------------------------------------------------------------
+# Vision 상태 → LLM 시스템 메시지 포맷터
+# ----------------------------------------------------------------------
+_EMOTION_KO = {
+    "angry": "화가 나신",
+    "disgust": "불쾌해 보이시는",
+    "fear": "불안해 보이시는",
+    "happy": "기분 좋으신",
+    "neutral": "평온하신",
+    "sad": "슬퍼 보이시는",
+    "surprise": "놀라신",
+    "unknown": "표정이 잘 보이지 않는",
+}
+
+
+def _format_vision_for_prompt(state: dict) -> str:
+    """vision JSON → 노인 친화 한글 컨텍스트.
+
+    예: "[감지 정보] 어르신이 카메라 앞에 계시고, 표정은 슬퍼 보입니다 (74%).
+         인식: 철수 어르신. 이 정보를 자연스럽게 반영해 답하되, 직접 언급하지 마세요."
+    """
+    presence = bool(state.get("presence"))
+    emotion = str(state.get("emotion") or "unknown").lower()
+    conf = float(state.get("emotion_conf") or 0.0)
+    name = str(state.get("face_name") or "")
+    fall = bool(state.get("fall_detected"))
+
+    if not presence:
+        return ("[감지 정보] 지금 카메라 앞에 어르신이 보이지 않습니다. "
+                "응답은 가볍고 짧게, 부담 없는 안부 위주로 해 주세요.")
+
+    parts = []
+    emo_ko = _EMOTION_KO.get(emotion, "")
+    if emo_ko:
+        parts.append(f"표정은 {emo_ko} 모습 (신뢰도 {int(conf*100)}%)")
+    if name:
+        parts.append(f"인식: {name}")
+    if fall:
+        parts.append("⚠️ 낙상이 감지되어 있음 — 즉시 안부와 함께 보호자/119 연락을 부드럽게 권유")
+    detail = ", ".join(parts) if parts else "어르신이 카메라 앞에 계심"
+    return (f"[감지 정보] {detail}. 이 정보를 자연스럽게 반영해 답하되, "
+            "분석 결과를 그대로 언급하지는 마세요.")
+
+
 def main():
     rclpy.init()
     node = LlmDialogueNode()
